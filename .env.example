# Frontend Environment Variables
VITE_API_URL=http://localhost:3000
VITE_INVITATION_UID=lucas-andressa
VITE_RECAPTCHA_MODE=checkbox
# Use a chave publica do reCAPTCHA, geralmente com prefixo 6L...
VITE_RECAPTCHA_SITE_KEY=cole-a-site-key-do-google
# Para reCAPTCHA Enterprise, use mode=enterprise e informe a site key do Enterprise.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=cole-a-site-key-enterprise
VITE_RECAPTCHA_ENTERPRISE_ACTION=wedding_wish

# Backend Environment Variables (for server)
# Supabase/Postgres principal. Use a connection string do Supabase com senha do banco.
# Recomendado na Hostinger: Transaction Pooler/Session Pooler com sslmode=require.
DATABASE_URL=postgresql://postgres.eszgihcpqbevbkvsnqww:SUA_SENHA_DO_BANCO@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Alias opcional se preferir separar visualmente no painel.
SUPABASE_DATABASE_URL=
SUPABASE_URL=https://eszgihcpqbevbkvsnqww.supabase.co
SUPABASE_ANON_KEY=cole-a-anon-public-key
# NUNCA use a service role no frontend. Se precisar guardar, somente backend/env da hospedagem.
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-somente-no-backend
ADMIN_SESSION_SECRET=gere-um-segredo-longo-aleatorio
# Use a chave secreta do reCAPTCHA no backend, nunca a chave publica/API key.
RECAPTCHA_SECRET_KEY=cole-a-secret-key-do-google
# Para reCAPTCHA Enterprise, informe tambem o projeto e a API key do Google Cloud.
RECAPTCHA_ENTERPRISE_PROJECT_ID=seu-project-id-google-cloud
RECAPTCHA_ENTERPRISE_API_KEY=sua-api-key-google-cloud
RECAPTCHA_ENTERPRISE_SITE_KEY=cole-a-site-key-enterprise
RECAPTCHA_ENTERPRISE_ACTION=wedding_wish
RECAPTCHA_ENTERPRISE_MIN_SCORE=0.5

# Google Sheets backup das confirmacoes e da lista total de convidados.
# Compartilhe a planilha com a conta de servico e informe o ID da planilha.
GOOGLE_SHEETS_SPREADSHEET_ID=1oDJ6s1JUpBlxasxxpeVzAku5tAjkjTXm8XNG8WvFYMc
GOOGLE_SHEETS_CONFIRMED_RANGE='Presença Confirmada'!A:E
GOOGLE_SHEETS_TOTAL_RANGE='Lista Total'!A:E
# Opção 1: caminho do JSON da conta de servico no servidor.
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
# Opção 2: JSON inteiro em uma variavel de ambiente.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Opção 3: JSON em base64, mais facil para paineis de hospedagem.
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
PORT=3000
