# Frontend Environment Variables
VITE_API_URL=http://localhost:3000
VITE_INVITATION_UID=lucas-andressa
VITE_RECAPTCHA_MODE=checkbox
# Use a chave publica do reCAPTCHA, geralmente com prefixo 6L...
VITE_RECAPTCHA_SITE_KEY=cole-a-site-key-do-google
# Para reCAPTCHA Enterprise, use mode=enterprise e informe a site key do Enterprise.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=cole-a-site-key-enterprise
VITE_RECAPTCHA_ENTERPRISE_ACTION=wedding_wish

# Backend Environment Variables (for server)
DATABASE_URL=postgresql://username:password@localhost:5432/sakeenah
ADMIN_SESSION_SECRET=gere-um-segredo-longo-aleatorio
# Use a chave secreta do reCAPTCHA no backend, nunca a chave publica/API key.
RECAPTCHA_SECRET_KEY=cole-a-secret-key-do-google
# Para reCAPTCHA Enterprise, informe tambem o projeto e a API key do Google Cloud.
RECAPTCHA_ENTERPRISE_PROJECT_ID=seu-project-id-google-cloud
RECAPTCHA_ENTERPRISE_API_KEY=sua-api-key-google-cloud
RECAPTCHA_ENTERPRISE_SITE_KEY=cole-a-site-key-enterprise
RECAPTCHA_ENTERPRISE_ACTION=wedding_wish
RECAPTCHA_ENTERPRISE_MIN_SCORE=0.5
PORT=3000
